# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# Required: Discord webhook the agent posts session updates / alerts to.
# Create one in Discord: Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL.
DISCORD_WEBHOOK_URL=

# Optional (Phase 1): free key from https://twelvedata.com/ — used as a fallback
# price source when Yahoo Finance goes stale/rate-limited. Bot works fine without it
# (falls back to Yahoo-only behavior, same as today).
TWELVEDATA_API_KEY=

# Optional (Phase 2, not active until broker.provider = "mt5" in config.json):
# credentials for the locally-running MetaTrader 5 terminal logged into IC Markets.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# Optional (not active until broker.provider = "ctrader" in config.json):
# IC Markets (or any broker/prop-firm) cTrader account via Spotware's Open API.
# See docs/ctrader_setup.md for the full walkthrough: register an app at
# https://openapi.ctrader.com, run `python ops/ctrader_auth.py` to authorize it and
# discover your account id, then fill these in.
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCOUNT_ID=

# Safety latch -- leave this EMPTY for demo trading. To ever trade a LIVE (real-money)
# cTrader or MT5 account, this must equal that account's exact id AND config.json's
# "live_trading": {"enabled": true} must also be set. Either one missing refuses to trade
# a live account. See broker/live.py and docs/ctrader_setup.md's go-live checklist.
LIVE_TRADING_CONFIRM=

# Optional (Phase 2, not active until broker.provider = "ibkr" in config.json):
# TWS/IB Gateway connection settings.
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
