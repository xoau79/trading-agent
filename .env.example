# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# Required: Discord webhook the agent posts session updates / alerts to.
# Create one in Discord: Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL.
DISCORD_WEBHOOK_URL=

# Optional (Phase 1): free key from https://twelvedata.com/ — used as a fallback
# price source when Yahoo Finance goes stale/rate-limited. Bot works fine without it
# (falls back to Yahoo-only behavior, same as today).
TWELVEDATA_API_KEY=

# Optional (Phase 2, not active until broker.provider = "mt5" in config.json):
# credentials for the locally-running MetaTrader 5 terminal logged into IC Markets.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# Optional (Phase 2, not active until broker.provider = "ibkr" in config.json):
# TWS/IB Gateway connection settings.
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
